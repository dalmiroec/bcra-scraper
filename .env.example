# ── Grafana Cloud Loki ───────────────────────────────────────────────────────
# Encontrás estos valores en: grafana.com → tu stack → "Details" → Loki
LOKI_URL=https://logs-prod-us-central1.grafana.net   # cambia la región si corresponde
LOKI_USER=123456                                      # tu Loki User ID (número)
LOKI_API_KEY=glc_eyJ...                              # Grafana Cloud API Key con scope "logs:write"

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6        # cada cuántas horas scrapear (recomendado: 6 o 12)
BCRA_DATE_FROM=2024-01-01      # fecha inicial del scraping histórico
DAYS_LOOKBACK=30               # en modo incremental, cuántos días hacia atrás revisar

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
